{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RunUpdates Metadata Schema v2",
  "type": "object",
  "required": ["meta_version", "build", "toolchain", "artifacts"],

  "properties": {
    "meta_version": {
      "type": "integer",
      "enum": [2],
      "description": "Metadata schema version."
    },

    "build": {
      "type": "object",
      "required": ["date", "commit", "branch", "workflow_run_id"],
      "properties": {
        "date": {
          "type": "string",
          "format": "date-time",
          "description": "UTC timestamp of the build."
        },
        "commit": {
          "type": "string",
          "pattern": "^[0-9a-fA-F]{7,40}$",
          "description": "Git commit hash used for this build."
        },
        "branch": {
          "type": "string",
          "description": "Git branch used for the build."
        },
        "workflow_run_id": {
          "type": "integer",
          "minimum": 1,
          "description": "GitHub Actions workflow run ID."
        }
      }
    },

    "toolchain": {
      "type": "object",
      "required": ["python", "pyinstaller", "builder_os"],
      "properties": {
        "python": {
          "type": "string",
          "description": "Python version used for the build."
        },
        "pyinstaller": {
          "type": "string",
          "description": "PyInstaller version used for freezing."
        },
        "builder_os": {
          "type": "string",
          "description": "OS used for the build environment."
        }
      }
    },

    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "type", "os", "arch", "size", "sha256", "crc32"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Filename of the artifact."
          },
          "type": {
            "type": "string",
            "enum": ["deb", "rpm", "zip", "tgz", "unknown"],
            "description": "Package type."
          },
          "os": {
            "type": "string",
            "enum": ["linux", "windows", "macos", "unknown"],
            "description": "Operating system target."
          },
          "arch": {
            "type": "string",
            "enum": ["amd64", "x86_64", "arm64", "unknown"],
            "description": "CPU architecture."
          },
          "size": {
            "type": "integer",
            "minimum": 1,
            "description": "File size in bytes."
          },
          "sha256": {
            "type": "string",
            "pattern": "^[0-9a-fA-F]{64}$",
            "description": "SHA‑256 checksum."
          },
          "crc32": {
            "type": "string",
            "pattern": "^[0-9a-fA-F]{8}$",
            "description": "CRC‑32 checksum."
          }
        }
      }
    }
  }
}
